# Copy to .env and fill in. .env is gitignored.

# Required for live Coordinator agent runs (Phase 10)
ANTHROPIC_API_KEY=

# Required for Phase 9 public exposure (skip if using cloudflared)
NGROK_AUTHTOKEN=

# SHARP / Prompt Opinion — verify in platform docs (RISKS Q1)
#
# Dev/P0 (local): generate a keypair with `uv run python scripts/dev_keypair.py`
# and point SHARP_PUBLIC_KEY_PEM at the generated public PEM. Leave SHARP_JWKS_URL
# commented out — the two are mutually exclusive.
SHARP_PUBLIC_KEY_PEM=.secrets/sharp_dev_pub.pem
# SHARP_JWKS_URL=https://app.promptopinion.ai/.well-known/jwks.json
SHARP_ISSUER=promptopinion.ai
SHARP_AUDIENCE=medrec-superpower

# Demo escape hatches — set to "1" to bypass a specific claim check when
# Prompt Opinion's emitted SHARP token uses different aud/iss values than ours.
# Signature, expiry, and required-claims are ALWAYS enforced. Default: enforced.
# MEDREC_SHARP_ALLOW_ANY_AUDIENCE=1
# MEDREC_SHARP_ALLOW_ANY_ISSUER=1

# Server
MEDREC_HOST=0.0.0.0
MEDREC_PORT=8765
MEDREC_TRANSPORT=streamable-http
MEDREC_LOG_LEVEL=INFO

# DNS-rebinding defense for the MCP streamable-HTTP transport.
# Default allowlist (when unset): 127.0.0.1, localhost, testserver.
# Comma-separated. Add your ngrok hostname for the demo path, e.g.:
#   MEDREC_ALLOWED_HOSTS=127.0.0.1,localhost,abc123.ngrok-free.app
# Or disable entirely when fronted by a trusted reverse proxy:
#   MEDREC_DISABLE_HOST_CHECK=1

# Environment marker — must be "production" to enable live JWKS fetch.
# Tests set this to "test" (see tests/conftest.py).
MEDREC_ENV=development
