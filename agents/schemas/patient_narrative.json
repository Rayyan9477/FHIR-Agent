          "type": "array"
        },
        "drug": {
          "minLength": 1,
          "title": "Drug",
          "type": "string"
        },
        "rxcui": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
